{
  "expo": {
    "name": "expensetracker",
    "slug": "expensetracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "",
    "scheme": "com.kunalsatpute.expensetracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kunalsatpute.expensetracker",
      "googleServicesFile": "./ios/GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.754664480885-r9clq013t1ttbvb2iipat8ctab39tjsg"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/splashscreen_logo.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS"
      ],
      "package": "com.kunalsatpute.expensetracker",
      "googleServicesFile": "./android/app/google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": ""
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splashscreen_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "manifestQueries": {
              "package": [
                "net.one97.paytm",
                "com.phonepe.app",
                "com.google.android.apps.nbu.paisa.user",
                "com.dreamplug.androidapp",
                "in.org.npci.upiapp"
              ],
              "intent": [
                {
                  "action": "android.intent.action.VIEW",
                  "data": {
                    "scheme": "upi"
                  }
                }
              ]
            }
          }
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f3cdbc6-2592-436c-9891-9ba302367a4b"
      }
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/7f3cdbc6-2592-436c-9891-9ba302367a4b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}