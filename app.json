{
  "expo": {
    "name": "expenseTracker",
    "slug": "expenseTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "",
    "scheme": "expensetracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "upi",
          "tez",
          "phonepe",
          "paytmmp", // ✅ was "paytm" — wrong scheme, must be "paytmmp"
          "credpay",
          "phonepe",
          "bhim"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png", // ✅ was missing — required field
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA"],
      "package": "com.kunalsatpute.expenseTracker",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "upi" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": ""
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splashscreen_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      // ✅ ADD THIS — injects Android <queries> block for package visibility
      [
        "expo-build-properties",
        {
          "android": {
            "manifestQueries": {
              "package": [
                "net.one97.paytm",
                "com.phonepe.app",
                "com.google.android.apps.nbu.paisa.user",
                "com.dreamplug.androidapp",
                "in.org.npci.upiapp"
              ],
              "intent": [
                {
                  "action": "android.intent.action.VIEW",
                  "data": { "scheme": "upi" }
                }
              ]
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f3cdbc6-2592-436c-9891-9ba302367a4b"
      }
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/7f3cdbc6-2592-436c-9891-9ba302367a4b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
